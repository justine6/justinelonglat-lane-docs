{
  "framework": null,
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },

    { "source": "/getting-started", "destination": "/docs.html" },
    { "source": "/tooling-setup", "destination": "/toolkit.html" },
    { "source": "/cicd-pipelines", "destination": "/docs.html" },
    { "source": "/architecture", "destination": "/architecture.html" },

    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/readme", "destination": "/README.html" },
    { "source": "/automation-toolkit", "destination": "/automation-toolkit.html" }
  ]
}
