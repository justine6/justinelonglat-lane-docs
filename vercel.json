{
  "framework": null,
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },

    { "source": "/README", "destination": "/README.html" },
    { "source": "/readme", "destination": "/README.html" },

    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/architecture", "destination": "/architecture.html" },
    { "source": "/automation-toolkit", "destination": "/automation-toolkit.html" },
    { "source": "/toolkit", "destination": "/toolkit.html" },
    { "source": "/sitemap", "destination": "/sitemap.html" }
  ]
}
